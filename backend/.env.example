# Trade Stag Backend — Environment Variables
# Copy this to .env and fill in values

# JWT Secret (generate a random 32+ char string)
JWT_SECRET=change-me-to-a-random-secret-string

# Port (Render sets this automatically)
PORT=8000

# Frontend URL (for CORS — set to your Vercel URL after deploying frontend)
FRONTEND_URL=https://trade-stag.vercel.app
